<?xml version="1.0" encoding="utf-8"?>
<!--
    Main layout for AndroidSettingsLaunchDiagnostic.
    Single-activity diagnostic tool for the Settings launch bug.

    Mode 1 - Direct: button tap calls startActivityForResult() immediately.
    Mode 2 - Dialog Flow: a confirmation dialog appears first, then Settings is
             opened from inside the dialog callback. This replicates the pattern
             that triggers the bug on affected devices.
-->
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/scroll_view_log"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:paddingBottom="80dp"
    android:clipToPadding="false">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="12dp">

        <!-- App Title -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Android Settings Launch Diagnostic"
            android:textSize="18sp"
            android:textStyle="bold"
            android:paddingBottom="4dp" />

        <!-- Device Info -->
        <TextView
            android:id="@+id/tv_device_info"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="11sp"
            android:fontFamily="monospace"
            android:background="#EEEEEE"
            android:padding="8dp"
            android:layout_marginBottom="10dp" />

        <!-- Workaround toggles -->
        <CheckBox
            android:id="@+id/cb_new_task"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Enable FLAG_ACTIVITY_NEW_TASK workaround (leave off to reproduce bug)"
            android:textSize="12sp" />

        <CheckBox
            android:id="@+id/cb_modern_api"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Use registerForActivityResult() instead of startActivityForResult()"
            android:textSize="12sp" />

        <CheckBox
            android:id="@+id/cb_fire_and_forget"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Use startActivity() — no result requested (fire-and-forget)"
            android:textSize="12sp" />

        <CheckBox
            android:id="@+id/cb_handler_post"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Wrap startActivityForResult() in Handler.post() (deferred by one frame)"
            android:textSize="12sp" />

        <CheckBox
            android:id="@+id/cb_trampoline"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Use trampoline activity (startActivityForResult from a normal task)"
            android:textSize="12sp"
            android:layout_marginBottom="12dp" />

        <!--
            Mode 1 - Direct (baseline).
            Button tap calls startActivityForResult() immediately; no dialog in between.
        -->

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Mode 1 — Direct Launch"
            android:textStyle="bold"
            android:textSize="13sp"
            android:textColor="#1565C0"
            android:background="#E3F2FD"
            android:padding="6dp"
            android:layout_marginBottom="4dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Opens a Settings screen directly from a button tap. Use as a baseline."
            android:textSize="11sp"
            android:textColor="#555555"
            android:layout_marginBottom="6dp" />

        <Button
            android:id="@+id/btn_accessibility"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="3dp"
            android:text="Accessibility Settings" />

        <Button
            android:id="@+id/btn_overlay"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="3dp"
            android:text="Draw Over Other Apps" />

        <Button
            android:id="@+id/btn_notification_listener"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="3dp"
            android:text="Notification Listener" />

        <Button
            android:id="@+id/btn_notification_settings"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="3dp"
            android:text="Notification Settings" />

        <Button
            android:id="@+id/btn_general_settings"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="3dp"
            android:text="General Settings" />

        <Button
            android:id="@+id/btn_dummy_activity"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:text="In-App Activity (DummyTargetActivity)" />

        <!--
            Mode 2 - Dialog Flow.
            A confirmation dialog appears first, then Settings is opened from inside
            the dialog callback. This replicates the production pattern that triggers
            the bug on affected devices.
        -->

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Mode 2 — Dialog Flow"
            android:textStyle="bold"
            android:textSize="13sp"
            android:textColor="#1B5E20"
            android:background="#E8F5E9"
            android:padding="6dp"
            android:layout_marginBottom="4dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Mirrors a production flow: a confirmation dialog appears first, then Settings is opened from inside the dialog callback. This is the pattern that triggers the bug on affected devices."
            android:textSize="11sp"
            android:textColor="#555555"
            android:layout_marginBottom="6dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Select which Settings screens to open:"
            android:textSize="12sp"
            android:layout_marginBottom="2dp" />

        <CheckBox
            android:id="@+id/cb_sim_accessibility"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Accessibility"
            android:checked="true"
            android:textSize="12sp" />

        <CheckBox
            android:id="@+id/cb_sim_overlay"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Draw Over Other Apps"
            android:checked="false"
            android:textSize="12sp" />

        <CheckBox
            android:id="@+id/cb_sim_notification_listener"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Notification Listener"
            android:checked="false"
            android:textSize="12sp" />

        <CheckBox
            android:id="@+id/cb_sim_notification_settings"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Post Notifications"
            android:checked="false"
            android:textSize="12sp"
            android:layout_marginBottom="6dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="12dp">

            <Button
                android:id="@+id/btn_start_flow"
                style="@style/Widget.Material3.Button"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:layout_marginEnd="4dp"
                android:text="Start Dialog Flow" />

            <Button
                android:id="@+id/btn_stop_flow"
                style="@style/Widget.Material3.Button.TonalButton"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:enabled="false"
                android:text="Stop Flow" />

        </LinearLayout>

        <!-- Log Controls -->

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="4dp">

            <Button
                android:id="@+id/btn_clear"
                style="@style/Widget.Material3.Button.TonalButton"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:layout_marginEnd="4dp"
                android:text="Clear Log" />

            <Button
                android:id="@+id/btn_copy"
                style="@style/Widget.Material3.Button.TonalButton"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:text="Copy to Clipboard" />

        </LinearLayout>

        <!-- Log Output -->

        <TextView
            android:id="@+id/tv_log"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:fontFamily="monospace"
            android:textSize="11sp"
            android:textColor="#1A1A1A"
            android:background="#FAFAFA"
            android:padding="6dp"
            android:minHeight="200dp" />

    </LinearLayout>

</ScrollView>